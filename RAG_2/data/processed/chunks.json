n 4 from pydantic import BaseModel 5 from prometheus_client import Counter, Histogram, Gauge, make_asgi_app 6 7 try: 8 from model.iris_model import predict 9 except ImportError: 10 logging.warning(\"Could not import 'model.iris_model'. Using mock prediction for testing.\") 11 def predict(features): 12 return int(features[0]) % 3 13 14 logging.basicConfig(level=logging.INFO) 15 logger = logging.getLogger(__name__) 16 17 app = FastAPI() 18 19 REQUESTS_TOTAL = Counter( 20 21 22 23 ) 'inference_requests_total', 'Total inference requests', ['method', 'endpoint', 'status'] 24 25 DURATION_SECONDS = Histogram( 26 27 28 29 30 ) 'inference_duration_seconds', 'Inference duration', ['method', 'endpoint'], buckets=[0.001, 0.005, 0.01, 0.05, 0.1, 0.5, 1.0] 31 32 PREDICTION_OUTPUT = Counter( 33 34 35 36 ) 'prediction_output_total', 'Prediction class distribution', ['class'] # e.g., \"0\", \"1\", \"2\" 37 38 MODEL_LOADED = Gauge('model_loaded', 'Model load status') 12 AI VIET NAM (AIO2025)""33 34 35 36 ) 'prediction_output_total', 'Prediction class distribution', ['class'] # e.g., \"0\", \"1\", \"2\" 37 38 MODEL_LOADED = Gauge('model_loaded', 'Model load status') 12 AI VIET NAM (AIO2025) aivietnam.edu.vn 39 MODEL_LOADED.set(1) 40 41 @app.middleware(\"http\") 42 async def monitor_requests(request: Request, call_next): 43 44 method = request.method path = request.url.path 45 46 if path == \"/metrics\": 47 return await call_next(request) 48 49 50 start_time = time.time() status_code = 500 51 52 try: 53 54 55 56 response = await call_next(request) status_code = response.status_code return response except Exception as e: 57 58 logger.error(f\"Internal Server Error: {e}\") raise e 59 finally: 60 process_time = time.time() - start_time 61 62 63 64 65 REQUESTS_TOTAL.labels( method=method, endpoint=path, status=status_code 66 ).inc() 67 68 DURATION_SECONDS.labels( 69 70 method=method, endpoint=path 71 ).observe(process_time) 72 73 metrics_app = make_asgi_app() 74 app.mount(\"/metrics\",""endpoint=path, status=status_code 66 ).inc() 67 68 DURATION_SECONDS.labels( 69 70 method=method, endpoint=path 71 ).observe(process_time) 72 73 metrics_app = make_asgi_app() 74 app.mount(\"/metrics\", metrics_app) 75 76 class FeaturesInput(BaseModel): features: list[float] # sepal_length, sepal_width, petal_length, petal_width 77 78 79 @app.post(\"/predict\") 80 def inference(input: FeaturesInput): 81 82 83 prediction = predict(input.features) PREDICTION_OUTPUT.labels(str(int(prediction))).inc() return {\"prediction\": int(prediction)} Tạo docker file cho server: dockerfile 1 FROM python:3.11 2 WORKDIR /app 13 AI VIET NAM (AIO2025) aivietnam.edu.vn 3 COPY . /app 4 RUN pip install fastapi uvicorn scikit-learn==1.5.2 joblib prometheus_client 5 CMD [\"uvicorn\", \"server.app:app\", \"--host\", \"0.0.0.0\", \"--port\", \"8000\", \"--reload\"] III.3. Bước 3: Cấu hình Prometheus và khởi chạy prometheus.yml 1 global: 2 3 scrape_interval: 15s # Pull mỗi 15s evaluation_interval: 15s # Eval rules 4 5""\"0.0.0.0\", \"--port\", \"8000\", \"--reload\"] III.3. Bước 3: Cấu hình Prometheus và khởi chạy prometheus.yml 1 global: 2 3 scrape_interval: 15s # Pull mỗi 15s evaluation_interval: 15s # Eval rules 4 5 scrape_configs: 6 7 8 job_name: \"ml-inference\" metrics_path: \"/metrics\" static_configs: 9 targets: [\"ml-service:8000\"] Tiếp đó, chạy lệnh docker-compose up -d để start. Truy cập localhost:8000/docs cho API docs, localhost:9090 cho Prometheus UI, và localhost:3000 cho Grafana (login adminadmin). III.4. Bước 4: Xây dựng Dashboard Grafana với Truy Vấn PromQL trên lưu lượng truy cập giả lập Chúng ta sẽ mô phỏng quá trình truy cập bằng code để có thể tiến hành query metrics Prometheus: dockerfile 1 import requests 2 import time 3 import random 4 import logging 5 from datetime import datetime 6 7 URL = \"http://localhost:8000/predict\" 8 LOG_FORMAT = \"%(asctime)s - %(levelname)s - %(message)s\" 9 logging.basicConfig(level=logging.INFO, format=LOG_FORMAT) 10 logger = logging.getLogger(\"Simulator\") 11""= \"http://localhost:8000/predict\" 8 LOG_FORMAT = \"%(asctime)s - %(levelname)s - %(message)s\" 9 logging.basicConfig(level=logging.INFO, format=LOG_FORMAT) 10 logger = logging.getLogger(\"Simulator\") 11 12 def generate_normal_iris(): 13 14 \"\"\"Sinh dữ liệu Iris chuẩn, phân phối đều\"\"\" return { 15 \"features\": [ 16 17 18 19 round(random.uniform(4.3, 7.9), 1), # sepal_length round(random.uniform(2.0, 4.4), 1), # sepal_width round(random.uniform(1.0, 6.9), 1), # petal_length round(random.uniform(0.1, 2.5), 1) # petal_width 14 AI VIET NAM (AIO2025) aivietnam.edu.vn 20 ] 21 } 22 23 def generate_drift_iris(): 24 return { 25 \"features\": [ 26 27 28 29 round(random.uniform(8.0, 10.0), 1), # Rất to round(random.uniform(4.5, 6.0), 1), round(random.uniform(7.0, 9.0), 1), round(random.uniform(3.0, 5.0), 1) # Rất dài 30 ] 31 } 32 33 def generate_error_payload(): 34 error_types = [ 35 36 37 38 {\"features\": [1, 2]}, # Thiếu features {\"features\": [\"a\", \"b\", \"c\", \"d\"]}, # Sai data type (str thay vì float)""# Rất dài 30 ] 31 } 32 33 def generate_error_payload(): 34 error_types = [ 35 36 37 38 {\"features\": [1, 2]}, # Thiếu features {\"features\": [\"a\", \"b\", \"c\", \"d\"]}, # Sai data type (str thay vì float) {\"wrong_key\": [1, 2, 3, 4]}, # Sai key {} # Empty 39 40 ] return random.choice(error_types) 41 42 def run_scenario(name, duration_sec, delay_range, data_func): 43 44 logger.info(f\"--- BẮT ĐẦU SCENARIO: {name} ({duration_sec}s) ---\") end_time = time.time() + duration_sec 45 46 while time.time() < end_time: 47 try: 48 49 50 payload = data_func() response = requests.post(URL, json=payload, timeout=5) if response.status_code == 200: 51 # Chỉ in dấu chấm để đỡ spam màn hình khi chạy nhanh, hoặc in chi tiết nếu cần 52 53 pred = response.json().get('prediction') print(f\" {name} | Pred: {pred} | Input: {payload['features']}\", end=\"\\r \") 54 else: 55 print(f\"\\n {name} | Status: {response.status_code} | Error: {response. text}\")